# Downloaded card art (136MB; regenerate with engine/scripts/download_card_images.py)
assets/card_images/cards/

# Regenerable source blob for the OCG card pool (4.6MB; rebuild the CSV with
# `engine/scripts/build_card_db.py --download`). The curated CSV is committed.
assets/card_databases/card_db_ocg_pre_synchro_v6.json

# Player state / progress — kept OUT of git so no git operation (checkout, pull,
# merge, reset) can ever clobber live gameplay. Sync across machines out-of-band
# (rsync) instead. These are everything the game writes as you play:
#   profile/            the save: DP, collection, stats, active deck, tournament
#   deck_blueprints/user/   decks you build in the browser
#   banlists/user/      custom Forbidden/Limited lists you save
#   replays/            recorded duels + verbose event/trace logs
/profile/
assets/deck_blueprints/user/
assets/banlists/user/
replays/

# OS
.DS_Store
